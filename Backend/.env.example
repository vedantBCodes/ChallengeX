PORT=4001
MONGO_URI=your_mongodb_uri

# Optional: enforce provider-backed UPI validation during signup.
# false = allow format-only validation if provider credentials are missing.
UPI_VALIDATE_ON_SIGNUP=false

# Razorpay VPA validation credentials
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxx
RAZORPAY_VALIDATE_VPA_URL=https://api.razorpay.com/v1/payments/validate/vpa
